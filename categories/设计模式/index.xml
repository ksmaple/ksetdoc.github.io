<h3 id="行为型模式11种对象间职责分配与交互">行为型模式（11种）：对象间职责分配与交互</h3>
<table>
  <thead>
      <tr>
          <th>模式</th>
          <th>解决的问题</th>
          <th>典型应用</th>
      </tr>
  </thead>
  <tbody>
      <tr>
          <td>责任链</td>
          <td>多对象依次处理请求</td>
          <td>Servlet Filter链、审批流程</td>
      </tr>
      <tr>
          <td>命令</td>
          <td>请求参数化、可撤销</td>
          <td>Runnable、线程池任务</td>
      </tr>
      <tr>
          <td>解释器</td>
          <td>定义文法解释器</td>
          <td>正则表达式、EL表达式</td>
      </tr>
      <tr>
          <td>迭代器</td>
          <td>顺序访问聚合对象</td>
          <td>Java Iterator、Stream</td>
      </tr>
      <tr>
          <td>中介者</td>
          <td>减少对象间直接交互</td>
          <td>MVC中的Controller、消息队列</td>
      </tr>
      <tr>
          <td>备忘录</td>
          <td>捕获和恢复对象状态</td>
          <td>游戏存档、数据库事务回滚</td>
      </tr>
      <tr>
          <td>观察者</td>
          <td>一对多依赖通知</td>
          <td>Spring Event、消息订阅</td>
      </tr>
      <tr>
          <td>状态</td>
          <td>状态驱动行为变化</td>
          <td>订单状态机、线程状态</td>
      </tr>
      <tr>
          <td>策略</td>
          <td>封装可互换算法</td>
          <td>Comparator、支付策略</td>
      </tr>
      <tr>
          <td>模板方法</td>
          <td>算法骨架由子类实现</td>
          <td>AbstractList、JUnit测试框架</td>
      </tr>
      <tr>
          <td>访问者</td>
          <td>分离算法与数据结构</td>
          <td>ASM字节码操作、编译器</td>
      </tr>
  </tbody>
</table>
