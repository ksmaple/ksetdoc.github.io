</span></span></span><span class="line"><span class="cl"><span class="n">strategy</span><span class="p">.</span><span class="na">pay</span><span class="p">(</span><span class="n">100</span><span class="p">.</span><span class="na">0</span><span class="p">);</span></span></span></code></pre></div></div>
