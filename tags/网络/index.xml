          <td>每次调用拷贝fd数组到内核</td>
      </tr>
      <tr>
          <td>epoll</td>
          <td>红黑树 + 就绪链表</td>
          <td>无限制</td>
          <td>O(1)活跃fd</td>
          <td>首次epoll_ctl拷贝，后续不拷贝</td>
      </tr>
  </tbody>
</table>
