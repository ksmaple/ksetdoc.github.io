<h2 id="根因分析">根因分析</h2>
<table>
  <thead>
      <tr>
          <th>根因</th>
          <th>现象</th>
          <th>验证方式</th>
      </tr>
  </thead>
  <tbody>
      <tr>
          <td>DNS解析慢</td>
          <td>首次请求慢，后续正常</td>
          <td>dig/nslookup看解析时间</td>
      </tr>
      <tr>
          <td>路由跳变</td>
          <td>traceroute路径不稳定</td>
          <td>多次traceroute对比</td>
      </tr>
      <tr>
          <td>TCP重传</td>
          <td>网络丢包或拥塞</td>
          <td>/proc/net/snmp重传率</td>
      </tr>
      <tr>
          <td>带宽打满</td>
          <td>延迟伴随丢包</td>
          <td>iftop/nload看流量</td>
      </tr>
      <tr>
          <td>连接数耗尽</td>
          <td>大量TIME_WAIT/CLOSE_WAIT</td>
          <td>ss -tan统计</td>
      </tr>
      <tr>
          <td>超时配置不当</td>
          <td>超时时间小于正常RTT</td>
          <td>对比ping延迟和超时配置</td>
      </tr>
  </tbody>
</table>
