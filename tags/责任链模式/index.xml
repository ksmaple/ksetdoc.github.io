</span></span></span><span class="line"><span class="cl"><span class="p">}</span><span class="w">
</span></span></span><span class="line"><span class="cl"><span class="w">
</span></span></span><span class="line"><span class="cl"><span class="c1">// 使用</span><span class="w">
</span></span></span><span class="line"><span class="cl"><span class="n">Handler</span><span class="w"> </span><span class="n">manager</span><span class="w"> </span><span class="o">=</span><span class="w"> </span><span class="k">new</span><span class="w"> </span><span class="n">Manager</span><span class="p">();</span><span class="w">
</span></span></span><span class="line"><span class="cl"><span class="n">Handler</span><span class="w"> </span><span class="n">director</span><span class="w"> </span><span class="o">=</span><span class="w"> </span><span class="k">new</span><span class="w"> </span><span class="n">Director</span><span class="p">();</span><span class="w">
</span></span></span><span class="line"><span class="cl"><span class="n">manager</span><span class="p">.</span><span class="na">setNext</span><span class="p">(</span><span class="n">director</span><span class="p">);</span><span class="w">
</span></span></span><span class="line"><span class="cl"><span class="w">
</span></span></span><span class="line"><span class="cl"><span class="n">manager</span><span class="p">.</span><span class="na">handle</span><span class="p">(</span><span class="k">new</span><span class="w"> </span><span class="n">Request</span><span class="p">(</span><span class="s">&#34;报销&#34;</span><span class="p">,</span><span class="w"> </span><span class="n">500</span><span class="p">));</span><span class="w">   </span><span class="c1">// 经理处理</span><span class="w">
</span></span></span><span class="line"><span class="cl"><span class="n">manager</span><span class="p">.</span><span class="na">handle</span><span class="p">(</span><span class="k">new</span><span class="w"> </span><span class="n">Request</span><span class="p">(</span><span class="s">&#34;报销&#34;</span><span class="p">,</span><span class="w"> </span><span class="n">3000</span><span class="p">));</span><span class="w">  </span><span class="o">//</span><span class="w"> </span><span class="n">总监处理</span></span></span></code></pre></div></div>
<h2 id="spring-过滤器链">Spring 过滤器链</h2>
