      </tr>
      <tr>
          <td>文本分类</td>
          <td>向量聚类</td>
          <td>新闻自动分类</td>
      </tr>
      <tr>
          <td>推荐系统</td>
          <td>用户/物品向量匹配</td>
          <td>相似商品推荐</td>
      </tr>
      <tr>
          <td>RAG检索</td>
          <td>文档切片向量化</td>
          <td>问答系统召回相关段落</td>
      </tr>
  </tbody>
</table>
