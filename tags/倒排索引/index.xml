  <thead>
      <tr>
          <th>概念</th>
          <th>说明</th>
          <th>类比关系型数据库</th>
      </tr>
  </thead>
  <tbody>
      <tr>
          <td>Index</td>
          <td>索引，文档的集合</td>
          <td>Database</td>
      </tr>
      <tr>
          <td>Document</td>
          <td>文档，一条JSON数据</td>
          <td>Row</td>
      </tr>
      <tr>
          <td>Mapping</td>
