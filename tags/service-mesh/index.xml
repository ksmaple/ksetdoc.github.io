<h3 id="sidecar模式演进">Sidecar模式演进</h3>
<table>
  <thead>
      <tr>
          <th>模式</th>
          <th>延迟</th>
          <th>资源占用</th>
          <th>适用场景</th>
      </tr>
  </thead>
  <tbody>
      <tr>
          <td>Sidecar（传统）</td>
          <td>1-2ms</td>
          <td>每Pod一个代理</td>
          <td>通用场景</td>
      </tr>
      <tr>
          <td>Sidecarless（Ambient）</td>
          <td>&lt;1ms</td>
