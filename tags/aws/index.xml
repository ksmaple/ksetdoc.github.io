      </tr>
      <tr>
          <td>资源标签管理</td>
          <td>按项目/环境打标签</td>
          <td>清晰成本归属</td>
      </tr>
      <tr>
          <td>闲置资源清理</td>
          <td>定期巡检释放不用的ECS、磁盘</td>
          <td>避免隐形浪费</td>
      </tr>
      <tr>
          <td>存储分层</td>
          <td>热数据SSD、冷数据归档</td>
          <td>存储成本降70%</td>
      </tr>
  </tbody>
</table>
<h3 id="多云策略">多云策略</h3>
<table>
  <thead>
      <tr>
          <th>策略</th>
          <th>说明</th>
          <th>风险</th>
      </tr>
  </thead>
  <tbody>
      <tr>
          <td>单一云深度使用</td>
          <td>一家云厂商用透</td>
          <td>厂商锁定风险</td>
      </tr>
      <tr>
          <td>多云容灾</td>
          <td>核心系统双云部署</td>
          <td>成本高、复杂度大</td>
      </tr>
      <tr>
          <td>云无关抽象</td>
          <td>上层代码不依赖云SDK</td>
          <td>需要自研适配层</td>
      </tr>
  </tbody>
</table>
