<h3 id="成本控制经验">成本控制经验</h3>
<table>
  <thead>
      <tr>
          <th>策略</th>
          <th>说明</th>
          <th>效果</th>
      </tr>
  </thead>
  <tbody>
      <tr>
          <td>包年包月+按量混合</td>
