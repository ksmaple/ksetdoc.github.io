          <td>范围查询需扫描全部分片</td>
      </tr>
      <tr>
          <td>范围分片</td>
          <td>create_time</td>
          <td>支持范围查询</td>
          <td>热点问题（新数据集中在最新分片）</td>
      </tr>
      <tr>
          <td>混合分片</td>
          <td>时间+哈希</td>
          <td>兼顾均匀与范围</td>
          <td>实现复杂</td>
      </tr>
  </tbody>
</table>
