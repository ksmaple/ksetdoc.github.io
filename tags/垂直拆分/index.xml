</span></span><span class="line"><span class="cl">├── user                    db1: order_1, order_3
</span></span><span class="line"><span class="cl">└── user_profile
</span></span><span class="line"><span class="cl">
</span></span><span class="line"><span class="cl">order_db
</span></span><span class="line"><span class="cl">└── order</span></span></code></pre></div></div>
