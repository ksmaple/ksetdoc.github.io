<h3 id="分布式id">分布式ID</h3>
<table>
  <thead>
      <tr>
          <th>方案</th>
          <th>优点</th>
          <th>缺点</th>
      </tr>
  </thead>
  <tbody>
      <tr>
          <td>数据库自增</td>
          <td>简单</td>
          <td>性能瓶颈，不适合分片</td>
      </tr>
      <tr>
          <td>Snowflake</td>
          <td>高性能，趋势递增</td>
          <td>时钟回拨问题</td>
      </tr>
      <tr>
          <td>号段模式</td>
          <td>批量获取，性能高</td>
          <td>依赖数据库</td>
      </tr>
      <tr>
          <td>UUID</td>
          <td>无中心</td>
          <td>无序，占用空间大</td>
      </tr>
  </tbody>
</table>
