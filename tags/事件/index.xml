      </tr>
      <tr>
          <td>ApplicationEventPublisher</td>
          <td>事件发布接口</td>
      </tr>
      <tr>
          <td>@EventListener</td>
          <td>标记方法为事件监听器</td>
      </tr>
      <tr>
          <td>ApplicationEventMulticaster</td>
          <td>事件广播器，管理监听器</td>
      </tr>
  </tbody>
</table>
