<h3 id="逻辑递进四种方式">逻辑递进四种方式</h3>
<table>
  <thead>
      <tr>
          <th>方式</th>
          <th>说明</th>
          <th>示例</th>
      </tr>
  </thead>
  <tbody>
      <tr>
          <td>时间顺序</td>
          <td>按步骤或阶段</td>
          <td>先…再…最后…</td>
      </tr>
      <tr>
          <td>结构顺序</td>
          <td>按组成部分</td>
          <td>架构分接入层、服务层、存储层</td>
      </tr>
      <tr>
          <td>重要性顺序</td>
          <td>按优先级</td>
          <td>高优/中优/低优</td>
      </tr>
      <tr>
          <td>演绎顺序</td>
          <td>大前提→小前提→结论</td>
          <td>所有A是B，C是A，所以C是B</td>
      </tr>
  </tbody>
</table>
