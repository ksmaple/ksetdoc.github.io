  <tbody>
      <tr>
          <td>左旋/右旋</td>
          <td>局部不平衡</td>
          <td>旋转节点，调整父子关系</td>
      </tr>
      <tr>
          <td>变色</td>
          <td>双红冲突</td>
          <td>父、叔、祖父节点颜色翻转</td>
      </tr>
      <tr>
          <td>LR/RL双旋</td>
