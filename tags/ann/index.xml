      <tr>
          <td>成本</td>
          <td>低</td>
          <td>高</td>
      </tr>
      <tr>
          <td>幻觉控制</td>
          <td>好（基于检索内容）</td>
          <td>一般</td>
      </tr>
      <tr>
          <td>适用场景</td>
          <td>知识库问答、客服</td>
          <td>特定风格/格式</td>
      </tr>
  </tbody>
</table>
